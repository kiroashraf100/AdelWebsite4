{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/en", "destination": "/?lang=en" },
    { "source": "/de", "destination": "/?lang=de" },
    { "source": "/ru", "destination": "/?lang=ru" },
    { "source": "/ar", "destination": "/" }
  ]
}